# =============================================================================
# Matomo Docker Compose - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Database ---
MARIADB_PASSWORD=change_me_to_a_strong_password
MARIADB_ROOT_PASSWORD=change_me_to_a_strong_root_password

# --- Matomo ---
# Domain where Matomo will be accessible (used by Traefik & cron archiver)
MATOMO_DOMAIN=analytics.yourdomain.com

# Port to expose Matomo on the host (Coolify/Traefik proxies to this)
MATOMO_PORT=8080

# PHP memory limit (512M is recommended, increase for large sites)
PHP_MEMORY_LIMIT=512M
